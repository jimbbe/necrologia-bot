{
  "name": "whatsapp-grok-bridge",
  "version": "3.0.0",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/admin',{recursive:true});fs.rmSync('dist/admin/public',{recursive:true,force:true});fs.cpSync('src/admin/public','dist/admin/public',{recursive:true})\"",
    "start": "node dist/index.js"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "grok",
    "xai",
    "baileys"
  ],
  "author": "",
  "license": "ISC",
  "description": "Bot WhatsApp ↔ Grok (xAI)",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.21",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "openai": "^6.25.0",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0"
  }
}
