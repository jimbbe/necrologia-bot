# =============================================
# REQUERIDO
# =============================================

# API key de xAI (Grok). Obtener en: https://console.x.ai/
XAI_API_KEY=

# Password para el panel de administración web (QR scan, whitelist, logs)
# Si se omite, el admin panel no arranca
ADMIN_PASSWORD=


# =============================================
# MODO DE OPERACIÓN
# =============================================

# PREVIEW_ONLY=false → modo completo con Puppeteer (publica en amcannunci.it)
# PREVIEW_ONLY=true  → solo preview de texto, sin Puppeteer
PREVIEW_ONLY=false

# DRY_RUN=false → submit real. DRY_RUN=true → llena el form pero NO envía.
DRY_RUN=false


# =============================================
# CREDENCIALES AMCANNUNCI (requerido si PREVIEW_ONLY=false)
# =============================================

AMC_USERNAME=
AMC_PASSWORD=


# =============================================
# OPCIONAL
# =============================================

# API key de Groq (transcripción de audio). Si se omite, audio no disponible.
GROQ_API_KEY=

# AI_MODEL=grok-4-1-fast
# MAX_HISTORY=30
# SESSION_TIMEOUT_MS=1800000
# AMC_BASE_URL=https://www.amcannunci.it
# ADMIN_PORT=3000
