# Variables de entorno para Hostinger VPS / Docker Manager

# Dominio público
FRONTEND_DOMAIN=tudominio.com
FRONTEND_URL=https://tudominio.com
BACKEND_URL=https://tudominio.com

# Requeridas
XAI_API_KEY=
ADMIN_PASSWORD=
AMC_USERNAME=
AMC_PASSWORD=

# Opcionales
GROQ_API_KEY=
AI_MODEL=grok-4-1-fast
MAX_HISTORY=30
AMC_BASE_URL=https://www.amcannunci.it
SESSION_TIMEOUT_MS=1800000
DRY_RUN=false
PREVIEW_ONLY=false
ADMIN_HOST=0.0.0.0
ADMIN_PORT=3000
